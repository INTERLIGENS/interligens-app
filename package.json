{
  "name": "interligens-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:deploy": "prisma migrate deploy --schema=prisma/schema.prod.prisma",
    "db:status": "prisma migrate status",
    "vercel-build": "prisma generate --schema prisma/schema.prod.prisma && next build",
    "seed:sources": "tsx scripts/seed-sources.ts",
    "seed:kol": "tsx scripts/seed/run.ts",
    "seed:densify": "tsx scripts/seed/densify.ts",
    "osint:wallets": "tsx scripts/osint/run.ts",
    "seed:tokens": "tsx scripts/seed/data/token-links.ts",
    "seed:snapshots": "tsx scripts/seed/data/evidence-snapshots.ts",
    "seed:snapshots:upload": "tsx scripts/osint/uploadEvidence.ts",
    "seed:narrative-scripts": "tsx prisma/seeds/narrative-scripts.ts",
    "watcher:v2": "tsx scripts/watcher/watcherV2.ts",
    "watcher:v2:dry": "DRY_RUN=true tsx scripts/watcher/watcherV2.ts",
    "security:center:seed": "tsx scripts/seed/securityCenter.ts",
    "security:center:check": "tsx scripts/securityCenterCheck.ts",
    "legal:wording": "bash scripts/legal-wording-check.sh",
    "prefreeze:check": "bash scripts/prefreeze-check.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
