    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@dagrejs/dagre": "^2.0.4",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^6.19.3",
    "@sparticuz/chromium-min": "^143.0.4",
    "@types/d3": "^7.4.3",
    "@vercel/analytics": "^1.6.1",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "d3": "^7.9.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.10",
    "lucide-react": "^1.7.0",
    "next": "16.1.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "prisma": "^6.19.3",
    "puppeteer-core": "^24.38.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
