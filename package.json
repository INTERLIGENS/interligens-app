{
  "name": "interligens-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:deploy": "prisma migrate deploy --schema=prisma/schema.prod.prisma",
    "db:status": "prisma migrate status",
    "vercel-build": "prisma generate --schema prisma/schema.prod.prisma && prisma migrate deploy --schema prisma/schema.prod.prisma && next build",
    "seed:sources": "tsx scripts/seed-sources.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "@vercel/analytics": "^1.6.1",
    "better-sqlite3": "^12.6.2",
    "csv-parse": "^6.1.0",
    "next": "16.1.6",
    "pdf-parse": "^2.4.5",
    "prisma": "^5.22.0",
    "puppeteer": "^24.37.5",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
