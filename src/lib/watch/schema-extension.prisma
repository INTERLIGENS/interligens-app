// CREATE INDEX "WatchedToken_userEmail_idx" ON "WatchedToken"("userEmail");

model WatchedToken {
  id          String    @id @default(cuid())
  userEmail   String
  mint        String
  chain       String
  symbol      String?
  lastScore   Int?
  lastChecked DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userEmail, mint, chain])
  @@index([userEmail])
}
