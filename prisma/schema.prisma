generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SourceRegistry {
  id                String           @id @default(cuid())
  handle            String?          @unique
  sourceName        String
  name              String           @unique
  sourceType        String           @default("other")
  url               String?
  homepageUrl       String?
  description       String?
  defaultChain      String?
  defaultLabelType  String?
  defaultLabel      String?
  defaultVisibility String           @default("internal_only")
  license           String?
  tosRisk           String           @default("low")
  trusted           Boolean          @default(false)
  status            String           @default("active")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  batches           IngestionBatch[]
  templates         SourceTemplate[]
}

model IngestionBatch {
  id                  String          @id @default(cuid())
  sourceId            String?
  status              String          @default("pending")
  inputType           String
  inputPayload        String
  totalRows           Int             @default(0)
  matchedAddrs        Int             @default(0)
  dedupedRows         Int             @default(0)
  warnings            String?
  approvedBy          String?
  approvedAt          DateTime?
  processingStartedAt DateTime?
  processingEndedAt   DateTime?
  processedRows       Int             @default(0)
  errorMessage        String?
  rolledBackAt        DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  labels              AddressLabel[]
  auditLogs           AuditLog[]
  source              SourceRegistry? @relation(fields: [sourceId], references: [id])
  rawDocuments        RawDocument[]
}

model RawDocument {
  id        String         @id @default(cuid())
  batchId   String
  content   String
  mimeType  String         @default("text/plain")
  createdAt DateTime       @default(now())
  batch     IngestionBatch @relation(fields: [batchId], references: [id])
}

model AddressLabel {
  id          String          @id @default(cuid())
  chain       String
  address     String
  labelType   String
  label       String
  confidence  String          @default("low")
  entityName  String?
  sourceName  String
  sourceUrl   String?
  evidence    String?
  visibility  String          @default("internal_only")
  license     String?
  tosRisk     String          @default("low")
  isActive    Boolean         @default(true)
  firstSeenAt DateTime        @default(now())
  lastSeenAt  DateTime        @default(now())
  batchId     String?
  batch       IngestionBatch? @relation(fields: [batchId], references: [id])

  @@unique([chain, address, labelType, label, sourceUrl], name: "dedup_key")
  @@index([chain, address])
  @@index([batchId])
}

model RiskSummaryCache {
  id        String   @id @default(cuid())
  chain     String
  address   String
  summary   String
  updatedAt DateTime @updatedAt

  @@unique([chain, address], name: "chain_address")
}

model AuditLog {
  id        String          @id @default(cuid())
  action    String
  actorId   String
  batchId   String?
  meta      String?
  createdAt DateTime        @default(now())
  batch     IngestionBatch? @relation(fields: [batchId], references: [id])
}

model SourceTemplate {
  id            String         @id @default(cuid())
  sourceId      String
  inputType     String
  columnMapping String
  rules         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  source        SourceRegistry @relation(fields: [sourceId], references: [id])
}

model CommunitySubmission {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String   @default("pending")
  chain           String
  address         String
  labelType       String
  label           String?
  message         String?
  evidenceUrl     String?
  txHash          String?
  reporterContact String?
  ipHash          String
  userAgentHash   String?
  source          String   @default("community")
  severityDerived String   @default("info")
  adminNotes      String?
  linkedBatchId   String?
}

model GraphCase {
  id           String      @id @default(cuid())
  title        String
  pivotAddress String
  chain        String
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  nodes        GraphNode[]
  edges        GraphEdge[]
}

model GraphNode {
  id       String      @id @default(cuid())
  caseId   String
  type     String
  label    String
  metadata String      @default("{}")
  posX     Float       @default(0)
  posY     Float       @default(0)
  flagged  Boolean     @default(false)
  case     GraphCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  edgesOut GraphEdge[] @relation("EdgeSource")
  edgesIn  GraphEdge[] @relation("EdgeTarget")
}

model GraphEdge {
  id         String    @id @default(cuid())
  caseId     String
  sourceId   String
  targetId   String
  relation   String
  evidence   String?
  confidence String    @default("MEDIUM")
  case       GraphCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  source     GraphNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target     GraphNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model WalletLabel {
  id          String   @id @default(cuid())
  address     String
  chain       String   // "evm" | "solana" | "any"
  label       String
  category    String   // "scammer" | "team" | "kol" | "cex" | "mixer" | "victim" | "other"
  confidence  String   @default("MEDIUM") // "HIGH" | "MEDIUM" | "LOW"
  source      String   // "admin" | "community" | "etherscan" | "osint_pdf" | ...
  sourceUrl   String?
  verified    Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([address])
  @@index([chain])
  @@index([category])
  @@index([verified])
}
