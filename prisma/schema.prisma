generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SourceRegistry {
  id                String           @id @default(cuid())
  handle            String?          @unique
  sourceName        String
  name              String           @unique
  sourceType        String           @default("other")
  url               String?
  homepageUrl       String?
  description       String?
  defaultChain      String?
  defaultLabelType  String?
  defaultLabel      String?
  defaultVisibility String           @default("internal_only")
  license           String?
  tosRisk           String           @default("low")
  trusted           Boolean          @default(false)
  status            String           @default("active")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  batches           IngestionBatch[]
  templates         SourceTemplate[]
}

model IngestionBatch {
  id                  String          @id @default(cuid())
  sourceId            String?
  status              String          @default("pending")
  inputType           String
  inputPayload        String
  totalRows           Int             @default(0)
  matchedAddrs        Int             @default(0)
  dedupedRows         Int             @default(0)
  warnings            String?
  approvedBy          String?
  approvedAt          DateTime?
  processingStartedAt DateTime?
  processingEndedAt   DateTime?
  processedRows       Int             @default(0)
  errorMessage        String?
  rolledBackAt        DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  labels              AddressLabel[]
  auditLogs           AuditLog[]
  source              SourceRegistry? @relation(fields: [sourceId], references: [id])
  rawDocuments        RawDocument[]
}

model RawDocument {
  id        String         @id @default(cuid())
  batchId   String
  content   String
  mimeType  String         @default("text/plain")
  createdAt DateTime       @default(now())
  batch     IngestionBatch @relation(fields: [batchId], references: [id])
}

model AddressLabel {
  id          String          @id @default(cuid())
  chain       String
  address     String
  labelType   String
  label       String
  confidence  String          @default("low")
  entityName  String?
  sourceName  String
  sourceUrl   String?
  evidence    String?
  visibility  String          @default("internal_only")
  license     String?
  tosRisk     String          @default("low")
  isActive    Boolean         @default(true)
  firstSeenAt DateTime        @default(now())
  lastSeenAt  DateTime        @default(now())
  batchId     String?
  batch       IngestionBatch? @relation(fields: [batchId], references: [id])

  @@unique([chain, address, labelType, label, sourceUrl], name: "dedup_key")
  @@index([chain, address])
  @@index([batchId])
}

model RiskSummaryCache {
  id        String   @id @default(cuid())
  chain     String
  address   String
  summary   String
  updatedAt DateTime @updatedAt

  @@unique([chain, address], name: "chain_address")
}

model AuditLog {
  id        String          @id @default(cuid())
  action    String
  actorId   String
  batchId   String?
  meta      String?
  createdAt DateTime        @default(now())
  batch     IngestionBatch? @relation(fields: [batchId], references: [id])
}

model SourceTemplate {
  id            String         @id @default(cuid())
  sourceId      String
  inputType     String
  columnMapping String
  rules         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  source        SourceRegistry @relation(fields: [sourceId], references: [id])
}

model CommunitySubmission {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String   @default("pending")
  chain           String
  address         String
  labelType       String
  label           String?
  message         String?
  evidenceUrl     String?
  txHash          String?
  reporterContact String?
  ipHash          String
  userAgentHash   String?
  source          String   @default("community")
  severityDerived String   @default("info")
  adminNotes      String?
  linkedBatchId   String?
}

model GraphCase {
  id           String      @id @default(cuid())
  title        String
  pivotAddress String
  chain        String
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  edges        GraphEdge[]
  nodes        GraphNode[]
}

model GraphNode {
  id       String      @id @default(cuid())
  caseId   String
  type     String
  label    String
  metadata String      @default("{}")
  posX     Float       @default(0)
  posY     Float       @default(0)
  flagged  Boolean     @default(false)
  edgesOut GraphEdge[] @relation("EdgeSource")
  edgesIn  GraphEdge[] @relation("EdgeTarget")
  case     GraphCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model GraphEdge {
  id         String    @id @default(cuid())
  caseId     String
  sourceId   String
  targetId   String
  relation   String
  evidence   String?
  confidence String    @default("MEDIUM")
  case       GraphCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  source     GraphNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target     GraphNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model WalletLabel {
  id         String   @id @default(cuid())
  address    String
  chain      String
  label      String
  category   String
  confidence String   @default("MEDIUM")
  source     String
  sourceUrl  String?
  verified   Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([address])
  @@index([chain])
  @@index([category])
  @@index([verified])
}

model Influencer {
  id          String                @id @default(cuid())
  handle      String                @unique
  platform    String                @default("x")
  metadata    Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  score       InfluencerScore?
  signals     Signal[]
  candidates  SocialPostCandidate[]
  socialPosts SocialPost[]
  watchlist   SocialWatchlist?
  wallets     Wallet[]

  @@map("influencers")
}

model Wallet {
  id             String         @id @default(cuid())
  address        String
  chain          String         @default("ethereum")
  influencerId   String
  verifiedMethod String
  verifiedAt     DateTime
  confidence     Float          @default(1.0)
  ensName        String?
  createdAt      DateTime       @default(now())
  onchainEvents  OnchainEvent[]
  influencer     Influencer     @relation(fields: [influencerId], references: [id])

  @@unique([address, chain])
  @@map("wallets")
}

model SocialPost {
  id               String        @id @default(cuid())
  influencerId     String
  postUrl          String
  postedAtUtc      DateTime?
  capturedAtUtc    DateTime
  textExcerpt      String?       @db.VarChar(500)
  screenshotSha256 String?
  htmlSha256       String?
  manifestSha256   String?
  storageKeys      Json?
  captureStatus    CaptureStatus @default(PENDING)
  errors           String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  signals          Signal[]
  influencer       Influencer    @relation(fields: [influencerId], references: [id])

  @@map("social_posts")
}

model OnchainEvent {
  id            String   @id @default(cuid())
  txHash        String   @unique
  walletAddress String
  chain         String   @default("ethereum")
  blockTimeUtc  DateTime
  blockNumber   Int
  tokenAddress  String?
  direction     String?
  amountRaw     String?
  amountUsd     Float?
  counterparty  String?
  rawJson       Json?
  createdAt     DateTime @default(now())
  wallet        Wallet   @relation(fields: [walletAddress, chain], references: [address, chain])
  signals       Signal[]

  @@map("onchain_events")
}

model Signal {
  id                       String        @id @default(cuid())
  type                     String
  influencerId             String
  walletAddress            String?
  tokenAddress             String?
  t0PostUrl                String?
  t0PostedAtUtc            DateTime?
  t0CapturedAtUtc          DateTime?
  t0CapturedManifestSha256 String?
  t0Post                   DateTime?
  t1TxHash                 String?
  t1BlockNumber            Int?
  t1BlockTimeUtc           DateTime?
  t1Event                  DateTime?
  direction                String?
  amountRaw                String?
  holdingBeforeRaw         String?
  soldPctOfHolding         Float?
  windowBucket             String?
  windowMinutes            Int?
  severity                 String?
  confidence               Float?
  evidenceManifestSha256   String?
  evidenceRefs             Json?
  socialPostId             String?
  onchainEventId           String?
  notes                    String?
  createdAt                DateTime      @default(now())
  influencer               Influencer    @relation(fields: [influencerId], references: [id])
  onchainEvent             OnchainEvent? @relation(fields: [onchainEventId], references: [id])
  socialPost               SocialPost?   @relation(fields: [socialPostId], references: [id])

  @@map("signals")
}

model InfluencerScore {
  id            String     @id @default(cuid())
  influencerId  String     @unique
  periodDays    Int        @default(30)
  score         Int        @default(0)
  blatantCount  Int        @default(0)
  probableCount Int        @default(0)
  possibleCount Int        @default(0)
  updatedAt     DateTime   @default(now())
  influencer    Influencer @relation(fields: [influencerId], references: [id])

  @@map("influencer_scores")
}

model IntakeRecord {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  status           String   @default("pending")
  inputType        String
  sourceRef        String?
  sourceId         String?
  submittedBy      String?
  provenance       String   @default("{}")
  parserUsed       String   @default("unknown")
  extractVersion   String   @default("v1")
  rawText          String?
  rawTextTruncated Boolean  @default(false)
  extracted        String   @default("{}")
  classification   String   @default("rawdoc")
  routerConfidence Float    @default(0)
  extractWarnings  String   @default("[]")
  pendingBatch     Boolean  @default(false)
  linkedBatchId    String?
  linkedBatchId2   String?
  ipHash           String?
  userAgentHash    String?
  adminNotes       String?

  @@map("IntakeRecord")
}

model KolProfile {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  handle          String        @unique
  platform        String        @default("x")
  displayName     String?
  label           String        @default("unknown")
  riskFlag        String        @default("unverified")
  sourceIntakeIds String        @default("[]")
  confidence      String        @default("low")
  status          String        @default("active")
  bio             String?
  followerCount   Int?
  notes           String?
  pricePerPost    Float?
  tags            String        @default("[]")
  tier            String?
  rugCount        Int           @default(0)
  totalScammed    Float?
  verified        Boolean       @default(false)
  evmAddress      String?
  exitDate        DateTime?
  exitNarrative   String?
  exitPostUrl     String?
  totalDocumented Float?        @default(0)
  kolCases        KolCase[]
  evidences       KolEvidence[]
  kolWallets      KolWallet[]

  @@map("KolProfile")
}

model KolWallet {
  id          String     @id @default(cuid())
  createdAt   DateTime   @default(now())
  kolHandle   String
  address     String
  chain       String     @default("SOL")
  label       String?
  status      String     @default("active")
  claimType   String?    @default("source_attributed")
  sourceLabel String?
  sourceUrl   String?
  kol         KolProfile @relation(fields: [kolHandle], references: [handle])
}

model KolCase {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  kolHandle       String
  caseId          String
  role            String     @default("promoter")
  paidUsd         Float?
  evidence        String?
  claimType       String?    @default("analytical_estimate")
  confidenceLevel String?    @default("provisional")
  lastReviewedAt  DateTime?  @default(now()) @db.Timestamp(6)
  methodologyRef  String?    @default("/en/methodology")
  sourceLabel     String?
  sourceUrl       String?
  versionNote     String?
  kol             KolProfile @relation(fields: [kolHandle], references: [handle])
}

model KolEvidence {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  kolHandle     String
  type          String
  label         String
  description   String?
  wallets       String     @default("[]")
  amountUsd     Float?
  txCount       Int?       @default(0)
  dateFirst     DateTime?
  dateLast      DateTime?
  token         String?
  sampleTx      String?
  sourceUrl     String?
  twitterPost   String?
  postTimestamp DateTime?
  deltaMinutes  Int?
  rawJson       String?
  kol           KolProfile @relation(fields: [kolHandle], references: [handle])
}

model WatchSource {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  name         String
  url          String    @unique
  investigator String    @default("@david")
  tags         String    @default("[]")
  active       Boolean   @default(true)
  lastChecked  DateTime?
  lastHash     String?
  lastIntakeId String?
  errorCount   Int       @default(0)

  @@map("WatchSource")
}

model DomainIoc {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  domain         String   @unique
  labelType      String   @default("phishing")
  confidence     String   @default("low")
  status         String   @default("active")
  sourceIntakeId String?
  notes          String?

  @@map("DomainIoc")
}

model SocialWatchlist {
  id             String     @id @default(cuid())
  influencerId   String     @unique
  handle         String
  provider       String     @default("nitter_rss")
  status         String     @default("active")
  lastCheckedAt  DateTime?
  lastSeenPostId String?
  errorMessage   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  influencer     Influencer @relation(fields: [influencerId], references: [id])

  @@map("social_watchlist")
}

model SocialPostCandidate {
  id                 String     @id @default(cuid())
  influencerId       String
  watchlistId        String?
  postUrl            String
  postId             String
  discoveredAtUtc    DateTime   @default(now())
  postedAtUtc        DateTime?
  sourceProvider     String
  status             String     @default("new")
  attempts           Int        @default(0)
  lastAttemptAtUtc   DateTime?
  errorMessage       String?
  linkedSocialPostId String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  influencer         Influencer @relation(fields: [influencerId], references: [id])

  @@unique([postId, influencerId])
  @@map("social_post_candidates")
}

model AlertSubscription {
  id                String          @id @default(cuid())
  email             String?
  webhookUrl        String?
  handles           String          @default("[]")
  severityThreshold String          @default("PROBABLE")
  status            String          @default("active")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deliveries        AlertDelivery[]

  @@map("alert_subscriptions")
}

model AlertDelivery {
  id             String            @id @default(cuid())
  subscriptionId String
  signalId       String
  status         String            @default("pending")
  channel        String
  deliveredAt    DateTime?
  error          String?
  createdAt      DateTime          @default(now())
  subscription   AlertSubscription @relation(fields: [subscriptionId], references: [id])

  @@map("alert_deliveries")
}

model CaseFile {
  id          String    @id @default(cuid())
  signalId    String    @unique
  storageKey  String?
  pdfSha256   String?
  status      String    @default("pending")
  generatedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@map("casefiles")
}

model KOLProfile {
  id           String        @id @default(cuid())
  handle       String        @unique
  platform     String
  displayName  String?
  followers    Int?
  avatarUrl    String?
  status       String        @default("active")
  totalScammed Float?
  rugCount     Int           @default(0)
  firstSeenAt  DateTime?
  lastSeenAt   DateTime?
  notes        String?
  verified     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  caseLinks    KOLCaseLink[]
  wallets      KOLWallet[]

  @@index([handle])
  @@index([platform])
}

model KOLWallet {
  id        String     @id @default(cuid())
  kolId     String
  address   String
  chain     String
  label     String?
  status    String     @default("active")
  totalIn   Float?
  totalOut  Float?
  createdAt DateTime   @default(now())
  kol       KOLProfile @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@index([kolId])
  @@index([address])
}

model KOLCaseLink {
  id        String     @id @default(cuid())
  kolId     String
  caseId    String
  role      String
  paidUsd   Float?
  evidence  String?
  createdAt DateTime   @default(now())
  kol       KOLProfile @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@index([kolId])
  @@index([caseId])
}

enum CaptureStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  BLOCKED
}
