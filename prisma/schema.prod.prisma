  engineVersion       String
  detectorsVersion    Json
  schemaVersion       Int
  cohortKey           String
  cohortPercentiles   Json
  dataSources         Json
  rawDataRef          String?
  registryDrivenScore Int
  behaviorDrivenScore Int
  displayScore        Int
  confidenceLevel     String
  coverageLevel       String
  dominantDriver      String
  displayReason       String
  signalsCount        Int
  triggeredBy         MmTriggerType
  triggeredByRef      String?
  durationMs          Int
  errors              Json?
  createdAt           DateTime       @default(now())

  detectorOutputs MmDetectorOutput[]

  @@index([subjectId, chain])
  @@index([createdAt])
}

model MmDetectorOutput {
  id              String         @id @default(cuid())
  scanRunId       String
  detectorType    MmDetectorType
  detectorVersion String
  score           Int
  signalsCount    Int
  signals         Json
  evidence        Json
