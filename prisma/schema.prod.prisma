  name        String
  externalRef String?
  environment String   @default("prod") // prod | staging | preview | local | shared | unknown
  isCritical  Boolean  @default(false)
  owner       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

