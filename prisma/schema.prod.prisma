model MmCohortPercentile {
  id                   String   @id @default(cuid())
  cohortKey            String
  metricName           String
  p50                  Float
  p75                  Float
  p90                  Float
  p95                  Float
  p99                  Float
  sampleSize           Int
  excludedFlaggedCount Int
  computedAt           DateTime @default(now())
  schemaVersion        Int      @default(1)
  notes                String?  @db.Text

  @@unique([cohortKey, metricName, schemaVersion])
