// ─── MM Pattern Engine (release surface) ──────────────────────────────────
// Scope: scan persistence + cohort baselines only. Registry sub-module
// (MmEntity, MmAttribution, etc.) is intentionally excluded from this
// release — see src/lib/mm/index.ts and docs in commit message.

enum MmRiskBand {
  GREEN
  YELLOW
  ORANGE
  RED
}

enum MmChain {
  SOLANA
  ETHEREUM
  BASE
  ARBITRUM
  OPTIMISM
  BNB
  POLYGON
}

enum MmSubjectType {
  WALLET
  TOKEN
  ENTITY
}

enum MmTriggerType {
  CRON
  API_PUBLIC
  API_ADMIN
  TIGERSCORE_INTEGRATION
  BATCH_SCAN
}

enum MmDetectorType {
  WASH_TRADING
  CLUSTER_COORDINATION
  CONCENTRATION_ABNORMALITY
  PRICE_ASYMMETRY
  POST_LISTING_PUMP
  KNOWN_ENTITY_FLOOR
  FAKE_LIQUIDITY
}

enum MmSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model MmScanRun {
  id                  String         @id @default(cuid())
  subjectType         MmSubjectType
  subjectId           String
