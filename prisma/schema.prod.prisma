  revokedAt         DateTime?
  revokedReason     String?         @db.Text
  createdAt         DateTime        @default(now())

  mmEntity MmEntity @relation(fields: [mmEntityId], references: [id], onDelete: Cascade)

  @@index([walletAddress, chain])
  @@index([mmEntityId])
