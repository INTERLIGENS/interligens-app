generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model SourceRegistry {
  id                String           @id @default(cuid())
  handle            String?          @unique
  sourceName        String
  name              String           @unique
  sourceType        String           @default("other")
  url               String?
  homepageUrl       String?
  description       String?
  defaultChain      String?
  defaultLabelType  String?
  defaultLabel      String?
  defaultVisibility String           @default("internal_only")
  license           String?
  tosRisk           String           @default("low")
  trusted           Boolean          @default(false)
  status            String           @default("active")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  batches           IngestionBatch[]
  templates         SourceTemplate[]
}

model IngestionBatch {
  id                  String          @id @default(cuid())
  sourceId            String?
  status              String          @default("pending")
  inputType           String
  inputPayload        String
  totalRows           Int             @default(0)
  matchedAddrs        Int             @default(0)
  dedupedRows         Int             @default(0)
  warnings            String?
  approvedBy          String?
  approvedAt          DateTime?
  processingStartedAt DateTime?
  processingEndedAt   DateTime?
  processedRows       Int             @default(0)
  errorMessage        String?
  rolledBackAt        DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  labels              AddressLabel[]
  auditLogs           AuditLog[]
  source              SourceRegistry? @relation(fields: [sourceId], references: [id])
  rawDocuments        RawDocument[]
}

model RawDocument {
  id        String         @id @default(cuid())
  batchId   String
  content   String
  mimeType  String         @default("text/plain")
  createdAt DateTime       @default(now())
  batch     IngestionBatch @relation(fields: [batchId], references: [id])
}

model AddressLabel {
  id          String          @id @default(cuid())
  chain       String
  address     String
  labelType   String
  label       String
  confidence  String          @default("low")
  entityName  String?
  sourceName  String
  sourceUrl   String?
  evidence    String?
  visibility  String          @default("internal_only")
  license     String?
  tosRisk     String          @default("low")
  isActive    Boolean         @default(true)
  firstSeenAt DateTime        @default(now())
  lastSeenAt  DateTime        @default(now())
  batchId     String?
  batch       IngestionBatch? @relation(fields: [batchId], references: [id])

  @@unique([chain, address, labelType, label, sourceUrl], name: "dedup_key")
  @@index([chain, address])
  @@index([batchId])
}

model RiskSummaryCache {
  id        String   @id @default(cuid())
  chain     String
  address   String
  summary   String
  updatedAt DateTime @updatedAt

  @@unique([chain, address], name: "chain_address")
}

model AuditLog {
  id        String          @id @default(cuid())
  action    String
  actorId   String
  batchId   String?
  meta      String?
  createdAt DateTime        @default(now())
  batch     IngestionBatch? @relation(fields: [batchId], references: [id])
}

model SourceTemplate {
  id            String         @id @default(cuid())
  sourceId      String
  inputType     String
  columnMapping String
  rules         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  source        SourceRegistry @relation(fields: [sourceId], references: [id])
}

model CommunitySubmission {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String   @default("pending")
  chain           String
  address         String
  labelType       String
  label           String?
  message         String?
  evidenceUrl     String?
  txHash          String?
  reporterContact String?
  ipHash          String
  userAgentHash   String?
  source          String   @default("community")
  severityDerived String   @default("info")
  adminNotes      String?
  linkedBatchId   String?
}

model GraphCase {
  id           String      @id @default(cuid())
  title        String
  pivotAddress String
  chain        String
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  edges        GraphEdge[]
  nodes        GraphNode[]
}

model GraphNode {
  id       String      @id @default(cuid())
  caseId   String
  type     String
  label    String
  metadata String      @default("{}")
  posX     Float       @default(0)
  posY     Float       @default(0)
  flagged  Boolean     @default(false)
  edgesOut GraphEdge[] @relation("EdgeSource")
  edgesIn  GraphEdge[] @relation("EdgeTarget")
  case     GraphCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model GraphEdge {
  id         String    @id @default(cuid())
  caseId     String
  sourceId   String
  targetId   String
  relation   String
  evidence   String?
  confidence String    @default("MEDIUM")
  case       GraphCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  source     GraphNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target     GraphNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model WalletLabel {
  id         String   @id @default(cuid())
  address    String
  chain      String
  label      String
  category   String
  confidence String   @default("MEDIUM")
  source     String
  sourceUrl  String?
  verified   Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([address])
  @@index([chain])
  @@index([category])
  @@index([verified])
}

model Influencer {
  id          String                @id @default(cuid())
  handle      String                @unique
  platform    String                @default("x")
  metadata    Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  score       InfluencerScore?
  signals     Signal[]
  candidates  SocialPostCandidate[]
  socialPosts SocialPost[]
  watchlist   SocialWatchlist?
  wallets     Wallet[]

  @@map("influencers")
}

model Wallet {
  id             String         @id @default(cuid())
  address        String
  chain          String         @default("ethereum")
  influencerId   String
  verifiedMethod String
  verifiedAt     DateTime
  confidence     Float          @default(1.0)
  ensName        String?
  createdAt      DateTime       @default(now())
  onchainEvents  OnchainEvent[]
  influencer     Influencer     @relation(fields: [influencerId], references: [id])

  @@unique([address, chain])
  @@map("wallets")
}

model SocialPost {
  id               String        @id @default(cuid())
  influencerId     String
  postUrl          String
  postedAtUtc      DateTime?
  capturedAtUtc    DateTime
  textExcerpt      String?       @db.VarChar(500)
  screenshotSha256 String?
  htmlSha256       String?
  manifestSha256   String?
  storageKeys      Json?
  captureStatus    CaptureStatus @default(PENDING)
  errors           String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  signals          Signal[]
  influencer       Influencer    @relation(fields: [influencerId], references: [id])

  @@map("social_posts")
}

model OnchainEvent {
  id            String   @id @default(cuid())
  txHash        String   @unique
  walletAddress String
  chain         String   @default("ethereum")
  blockTimeUtc  DateTime
  blockNumber   Int
  tokenAddress  String?
  direction     String?
  amountRaw     String?
  amountUsd     Float?
  counterparty  String?
  rawJson       Json?
  createdAt     DateTime @default(now())
  wallet        Wallet   @relation(fields: [walletAddress, chain], references: [address, chain])
  signals       Signal[]

  @@map("onchain_events")
}

model Signal {
  id                       String        @id @default(cuid())
  type                     String
  influencerId             String
  walletAddress            String?
  tokenAddress             String?
  t0PostUrl                String?
  t0PostedAtUtc            DateTime?
  t0CapturedAtUtc          DateTime?
  t0CapturedManifestSha256 String?
  t0Post                   DateTime?
  t1TxHash                 String?
  t1BlockNumber            Int?
  t1BlockTimeUtc           DateTime?
  t1Event                  DateTime?
  direction                String?
  amountRaw                String?
  holdingBeforeRaw         String?
  soldPctOfHolding         Float?
  windowBucket             String?
  windowMinutes            Int?
  severity                 String?
  confidence               Float?
  evidenceManifestSha256   String?
  evidenceRefs             Json?
  socialPostId             String?
  onchainEventId           String?
  notes                    String?
  createdAt                DateTime      @default(now())
  influencer               Influencer    @relation(fields: [influencerId], references: [id])
  onchainEvent             OnchainEvent? @relation(fields: [onchainEventId], references: [id])
  socialPost               SocialPost?   @relation(fields: [socialPostId], references: [id])

  @@map("signals")
}

model InfluencerScore {
  id            String     @id @default(cuid())
  influencerId  String     @unique
  periodDays    Int        @default(30)
  score         Int        @default(0)
  blatantCount  Int        @default(0)
  probableCount Int        @default(0)
  possibleCount Int        @default(0)
  updatedAt     DateTime   @default(now())
  influencer    Influencer @relation(fields: [influencerId], references: [id])

  @@map("influencer_scores")
}

model IntakeRecord {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  status           String   @default("pending")
  inputType        String
  sourceRef        String?
  sourceId         String?
  submittedBy      String?
  provenance       String   @default("{}")
  parserUsed       String   @default("unknown")
  extractVersion   String   @default("v1")
  rawText          String?
  rawTextTruncated Boolean  @default(false)
  extracted        String   @default("{}")
  classification   String   @default("rawdoc")
  routerConfidence Float    @default(0)
  extractWarnings  String   @default("[]")
  pendingBatch     Boolean  @default(false)
  linkedBatchId    String?
  linkedBatchId2   String?
  ipHash           String?
  userAgentHash    String?
  adminNotes       String?

  @@map("IntakeRecord")
}

model KolProfile {
  id                        String                @id @default(cuid())
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  handle                    String                @unique
  platform                  String                @default("x")
  displayName               String?
  label                     String                @default("unknown")
  riskFlag                  String                @default("unverified")
  sourceIntakeIds           String                @default("[]")
  confidence                String                @default("low")
  status                    String                @default("active")
  bio                       String?
  followerCount             Int?
  notes                     String?
  pricePerPost              Float?
  tags                      String                @default("[]")
  tier                      String?
  rugCount                  Int                   @default(0)
  totalScammed              Float?
  verified                  Boolean               @default(false)
  evmAddress                String?
  exitDate                  DateTime?
  exitNarrative             String?
  exitPostUrl               String?
  totalDocumented           Float?                @default(0)
  last_reviewed_at          DateTime?
  version_note              String?
  publishable               Boolean               @default(false)
  publishStatus             String                @default("draft")
  internalNote              String?
  walletAttributionStatus   String                @default("none")
  evidenceStatus            String                @default("none")
  proceedsStatus            String                @default("none")
  editorialStatus           String                @default("pending")
  summary                   String?
  observedBehaviorSummary   String?
  documentedFacts           String?
  partialFacts              String?
  behaviorFlags             String                @default("[]")
  evidenceDepth             String                @default("none")
  completenessLevel         String                @default("incomplete")
  proceedsCoverage          String                @default("none")
  walletAttributionStrength String                @default("none")
  profileStrength           String                @default("minimal")
  lastEnrichedAt            DateTime?
  botifyDeal                Json?
  pdfUrl                    String?
  pdfGeneratedAt            DateTime?
  pdfScore                  Int?
  pdfVersion                Int                   @default(0)
  lastHeliusScan            DateTime?
  aliases                   KolAlias[]
  tokenLinks                KolTokenLink[]
  cashoutCache              Json?
  kolCases                  KolCase[]
  evidences                 KolEvidence[]
  kolWallets                KolWallet[]
  laundryTrails             LaundryTrail[]
  promotionMentions         KolPromotionMention[]
  tokenInvolvements         KolTokenInvolvement[]

  @@map("KolProfile")
}

model KolWallet {
  id                String                @id @default(cuid())
  createdAt         DateTime              @default(now())
  kolHandle         String
  address           String
  chain             String                @default("SOL")
  label             String?
  status            String                @default("active")
  claimType         String?               @default("source_attributed")
  sourceLabel       String?
  sourceUrl         String?
  confidence        String                @default("medium")
  attributionSource String?
  attributionNote   String?
  isPubliclyUsable  Boolean               @default(false)
  attributionStatus String                @default("review")
  discoveredAt      DateTime?
  kol               KolProfile            @relation(fields: [kolHandle], references: [handle])
  fundingEdgesFrom  WalletFundingEdge[]   @relation("FundingEdgeFrom")
  fundingEdgesTo    WalletFundingEdge[]   @relation("FundingEdgeTo")
  promotionMentions KolPromotionMention[]
  tokenInvolvements KolTokenInvolvement[]
}

model KolCase {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  kolHandle       String
  caseId          String
  role            String     @default("promoter")
  paidUsd         Float?
  evidence        String?
  claimType       String?    @default("analytical_estimate")
  confidenceLevel String?    @default("provisional")
  lastReviewedAt  DateTime?  @default(now()) @db.Timestamp(6)
  methodologyRef  String?    @default("/en/methodology")
  sourceLabel     String?
  sourceUrl       String?
  versionNote     String?
  kol             KolProfile @relation(fields: [kolHandle], references: [handle])
}

model KolEvidence {
  id            String     @id @default(cuid())
  createdAt     DateTime   @default(now())
  kolHandle     String
  type          String
  label         String
  description   String?
  wallets       String     @default("[]")
  amountUsd     Float?
  txCount       Int?       @default(0)
  dateFirst     DateTime?
  dateLast      DateTime?
  token         String?
  sampleTx      String?
  sourceUrl     String?
  twitterPost   String?
  postTimestamp DateTime?
  deltaMinutes  Int?
  rawJson       String?
  dedupKey      String?
  kol           KolProfile @relation(fields: [kolHandle], references: [handle])
}

model WatchSource {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  name         String
  url          String    @unique
  investigator String    @default("@david")
  tags         String    @default("[]")
  active       Boolean   @default(true)
  lastChecked  DateTime?
  lastHash     String?
  lastIntakeId String?
  errorCount   Int       @default(0)

  @@map("WatchSource")
}

model DomainIoc {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  domain         String   @unique
  labelType      String   @default("phishing")
  confidence     String   @default("low")
  status         String   @default("active")
  sourceIntakeId String?
  notes          String?

  @@map("DomainIoc")
}

model SocialWatchlist {
  id             String     @id @default(cuid())
  influencerId   String     @unique
  handle         String
  provider       String     @default("nitter_rss")
  status         String     @default("active")
  lastCheckedAt  DateTime?
  lastSeenPostId String?
  errorMessage   String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  influencer     Influencer @relation(fields: [influencerId], references: [id])

  @@map("social_watchlist")
}

model SocialPostCandidate {
  id                 String     @id @default(cuid())
  influencerId       String
  watchlistId        String?
  postUrl            String
  postId             String
  discoveredAtUtc    DateTime   @default(now())
  postedAtUtc        DateTime?
  sourceProvider     String
  status             String     @default("new")
  attempts           Int        @default(0)
  lastAttemptAtUtc   DateTime?
  errorMessage       String?
  linkedSocialPostId String?
  detectedTokens     String     @default("[]")
  detectedAddresses  String     @default("[]")
  signalTypes        String     @default("[]")
  signalScore        Int        @default(0)
  dedupKey           String?    @unique
  profileSnapshot    String?
  // Watcher V2 extended fields (added 2026-04-25)
  rawText            String?
  normalizedText     String?
  chain              String?
  screenshotUrl      String?
  severity           String?
  kolProfileId       String?
  campaignId         String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  influencer         Influencer @relation(fields: [influencerId], references: [id])
  campaign           WatcherCampaign? @relation(fields: [campaignId], references: [id])

  @@unique([postId, influencerId])
  @@index([campaignId])
  @@index([discoveredAtUtc(sort: Desc)])
  @@map("social_post_candidates")
}

model AlertSubscription {
  id                String          @id @default(cuid())
  email             String?
  webhookUrl        String?
  handles           String          @default("[]")
  severityThreshold String          @default("PROBABLE")
  status            String          @default("active")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deliveries        AlertDelivery[]

  @@map("alert_subscriptions")
}

model AlertDelivery {
  id             String            @id @default(cuid())
  subscriptionId String
  signalId       String
  status         String            @default("pending")
  channel        String
  deliveredAt    DateTime?
  error          String?
  createdAt      DateTime          @default(now())
  subscription   AlertSubscription @relation(fields: [subscriptionId], references: [id])

  @@map("alert_deliveries")
}

model CaseFile {
  id          String    @id @default(cuid())
  signalId    String    @unique
  storageKey  String?
  pdfSha256   String?
  status      String    @default("pending")
  generatedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@map("casefiles")
}

model KOLProfile {
  id           String        @id @default(cuid())
  handle       String        @unique
  platform     String
  displayName  String?
  followers    Int?
  avatarUrl    String?
  status       String        @default("active")
  totalScammed Float?
  rugCount     Int           @default(0)
  firstSeenAt  DateTime?
  lastSeenAt   DateTime?
  notes        String?
  verified     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  caseLinks    KOLCaseLink[]
  wallets      KOLWallet[]

  @@index([handle])
  @@index([platform])
}

model KOLWallet {
  id        String     @id @default(cuid())
  kolId     String
  address   String
  chain     String
  label     String?
  status    String     @default("active")
  totalIn   Float?
  totalOut  Float?
  createdAt DateTime   @default(now())
  kol       KOLProfile @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@index([kolId])
  @@index([address])
}

model KOLCaseLink {
  id        String     @id @default(cuid())
  kolId     String
  caseId    String
  role      String
  paidUsd   Float?
  evidence  String?
  createdAt DateTime   @default(now())
  kol       KOLProfile @relation(fields: [kolId], references: [id], onDelete: Cascade)

  @@index([kolId])
  @@index([caseId])
}

enum CaptureStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  BLOCKED
}

model XApiUsage {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  month        String    @unique
  callCount    Int       @default(0)
  estimatedUsd Decimal   @default(0) @db.Decimal(8, 2)
  lastCall     DateTime? @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
}

model WatchScan {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  handle        String
  status        String   @default("pending")
  postsFound    Int      @default(0)
  postsArchived Int      @default(0)
  errorMessage  String?
  durationMs    Int?
  triggeredBy   String   @default("cron")

  @@index([handle])
  @@index([createdAt])
}

// ─── INVESTIGATOR DASHBOARD ─────────────────────────────────────────────────

model InvestigatorAccess {
  id             String    @id @default(cuid())
  label          String // e.g. "BA-01", "advisor-gordon"
  accessCodeHash String // SHA-256 hex
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastUsedAt     DateTime?
  notes          String?

  sessions     InvestigatorSession[]
  auditLogs    InvestigatorAuditLog[]
  vaultProfile VaultProfile?
  vaultAudits  VaultAuditLog[]
  vaultNda     VaultNdaAcceptance?

  @@index([accessCodeHash])
}

model InvestigatorSession {
  id                   String    @id @default(cuid())
  investigatorAccessId String
  sessionTokenHash     String // SHA-256 of opaque session token
  createdAt            DateTime  @default(now())
  expiresAt            DateTime
  lastSeenAt           DateTime  @default(now())
  revokedAt            DateTime?
  ipHash               String?
  userAgent            String?

  access InvestigatorAccess @relation(fields: [investigatorAccessId], references: [id])

  @@index([sessionTokenHash])
  @@index([investigatorAccessId])
}

model InvestigatorAuditLog {
  id                   String   @id @default(cuid())
  investigatorAccessId String?
  eventType            String // login_success, login_fail, logout, access_denied
  route                String?
  timestamp            DateTime @default(now())
  ipHash               String?
  userAgent            String?
  metadata             Json?

  access InvestigatorAccess? @relation(fields: [investigatorAccessId], references: [id])

  @@index([investigatorAccessId])
  @@index([eventType])
  @@index([timestamp])
}

// ─────────────────────────────────────────────────────────────────────────────
// CASE INTELLIGENCE — BETA MODULE
// Appended to existing schema. One migration. ep-square-band only.
// ─────────────────────────────────────────────────────────────────────────────

enum IntelEntityType {
  ADDRESS // EOA / wallet (EVM or Solana)
  CONTRACT // Smart contract address
  TOKEN_CA // Token contract (launch / mint address)
  DOMAIN // Web domain or subdomain (lowercased)
  PROJECT // Named project — admin-seeded only
  PERSON // INTERNAL_ONLY — never retail-visible, never scores
}

enum IntelRiskClass {
  SANCTION // Statutory action: OFAC / AMF / FCA — hard caps apply
  HIGH // Confirmed threat: multi-source or strong technical signal
  MEDIUM // Flagged: single source, not corroborated
  LOW // Informational only
  UNKNOWN // Ingested, awaiting classification
}

enum MatchBasis {
  EXACT_ADDRESS // Checksummed address exact match
  EXACT_CONTRACT // Contract address exact match
  EXACT_DOMAIN // Lowercased domain exact match
  EXACT_TOKEN_CA // Token contract address exact match
  INFERRED_LINKAGE // Phase 3+ only. Never scores at beta.
  FUZZY_ALIAS // Internal only. Never scores at beta.
}

enum IntelDisplaySafety {
  INTERNAL_ONLY // Admin / analyst only. API suppresses for public routes.
  ANALYST_REVIEWED // Human-reviewed. Not yet cleared for scanner.
  RETAIL_SAFE // Cleared. Required for scanner display.
}

enum IntelCaseType {
  SCAM
  SANCTION
  ENFORCEMENT
  WARNING
  INVESTIGATION
}

enum IntelCaseStatus {
  ACTIVE
  MONITORING
  CLOSED
  DISPUTED
}

enum ArchivePlatform {
  X_TWITTER
  TELEGRAM
  YOUTUBE
  WEB_PAGE
  DAPP_SITE
  OTHER
}

enum CaptureType {
  WAYBACK_MACHINE
  SCREENSHOT
  VIDEO_CLIP
  PDF_EXPORT
  MANUAL_NOTE
}

enum EvidenceType {
  DELETED_POST
  PROMOTION
  DISCLAIMER
  CONTRACT_CLAIM
  IDENTITY_CLAIM // INTERNAL_ONLY always
  PRICE_CHART
  WALLET_MOVEMENT
  GENERAL
}

// ─────────────────────────────────────────────────────────────────────────────

model CanonicalEntity {
  id    String          @id @default(cuid())
  type  IntelEntityType
  // Normalized canonical value:
  // ADDRESS / CONTRACT / TOKEN_CA → lowercase hex (EVM) or raw base58 (Solana)
  // DOMAIN → stripped lowercase, no trailing slash, no protocol
  value String

  chain String? // "ethereum" | "solana" | "bsc" | null

  // Risk summary — derived from strongest active SourceObservation
  // Updated on every ingest pass. Never manually set.
  riskClass       IntelRiskClass @default(UNKNOWN)
  strongestSource String? // sourceSlug driving current riskClass
  sourceCount     Int            @default(1)
  firstSeenAt     DateTime
  lastSeenAt      DateTime

  // Dedup index: sha256(type + ":" + normalizedValue) — hex string
  dedupKey String @unique

  // Display gate — enforced at API level, not just UI
  displaySafety IntelDisplaySafety @default(INTERNAL_ONLY)
  reviewedBy    String?
  reviewedAt    DateTime?

  // Active flag — OFAC removals set isActive=false + deactivatedAt
  isActive      Boolean   @default(true)
  deactivatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  observations SourceObservation[]
  cases        EntityCase[]
  evidence     ArchivedEvidence[]

  @@unique([type, value])
  @@index([value])
  @@index([dedupKey])
  @@index([riskClass, isActive])
  @@index([type, isActive])
  @@map("intel_canonical_entities")
}

// ─────────────────────────────────────────────────────────────────────────────

model SourceObservation {
  id       String          @id @default(cuid())
  entityId String
  entity   CanonicalEntity @relation(fields: [entityId], references: [id])

  // Source identity
  sourceSlug  String // "ofac"|"amf"|"fca"|"scamsniffer"|"forta"|"goplus"
  sourceTier  Int // 1 = regulatory, 2 = technical
  externalId  String? // Source system record ID
  externalUrl String? // Linkable public record — shown in drawer

  // Classification
  riskClass  IntelRiskClass
  label      String? // Source's own label: "phishing"|"honeypot"|"rug_pull"
  matchBasis MatchBasis

  // Regulatory fields (Tier 1 only)
  jurisdiction   String? // "US"|"FR"|"UK"
  listType       String? // "SDN"|"AMF_BLACKLIST"|"FCA_WARNING"
  listIsActive   Boolean   @default(true)
  removedAt      DateTime? // Set when removed from official list
  lastVerifiedAt DateTime? // Last successful ingest confirming still active

  // Community fields (Tier 3 — Chainabuse, post-beta only)
  reportCount Int?

  // Timestamps
  ingestedAt DateTime  @default(now())
  observedAt DateTime? // Date of original event/listing (not our ingest)

  // Raw payload — keep for audit + debugging
  meta Json?

  // Beta constraint: one active observation per (entity, source)
  // On re-ingest: UPDATE in place. Historical versioning deferred post-beta.
  @@unique([entityId, sourceSlug])
  @@index([entityId, sourceTier])
  @@index([sourceSlug, ingestedAt])
  @@index([riskClass, listIsActive])
  @@map("intel_source_observations")
}

// ─────────────────────────────────────────────────────────────────────────────

model CaseRecord {
  id            String             @id @default(cuid())
  title         String
  caseType      IntelCaseType
  status        IntelCaseStatus    @default(ACTIVE)
  // Max 280 chars. Plain language. No legal determinations.
  summary       String?
  sourceSlug    String // Primary source driving this case
  externalRef   String? // DOJ/SEC case number, FCA action ref, etc.
  externalUrl   String?
  reportedAt    DateTime?
  resolvedAt    DateTime?
  displaySafety IntelDisplaySafety @default(INTERNAL_ONLY)
  reviewedBy    String?
  reviewedAt    DateTime?
  meta          Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  entities EntityCase[]
  evidence ArchivedEvidence[]

  @@index([caseType, status])
  @@index([displaySafety])
  @@map("intel_case_records")
}

// ─────────────────────────────────────────────────────────────────────────────

model EntityCase {
  entityId   String
  caseId     String
  // "defendant"|"wallet"|"domain"|"co-operator"|"victim"
  role       String?
  matchBasis MatchBasis
  entity     CanonicalEntity @relation(fields: [entityId], references: [id])
  case       CaseRecord      @relation(fields: [caseId], references: [id])

  @@id([entityId, caseId])
  @@map("intel_entity_cases")
}

// ─────────────────────────────────────────────────────────────────────────────

model IntelIngestionBatch {
  id             String    @id @default(cuid())
  sourceSlug     String
  startedAt      DateTime
  completedAt    DateTime?
  // "running"|"success"|"partial"|"failed"
  status         String
  recordsFetched Int?
  recordsNew     Int?
  recordsUpdated Int?
  recordsRemoved Int? // Critical: track OFAC removals explicitly
  errorMessage   String?
  // "cron"|"manual"|"admin:{handle}"
  triggeredBy    String?
  createdAt      DateTime  @default(now())

  @@index([sourceSlug, startedAt])
  @@map("intel_ingestion_batches")
}

// ─────────────────────────────────────────────────────────────────────────────

model IntelAuditLog {
  id         String   @id @default(cuid())
  // "system"|"cron:{slug}"|"admin:{handle}"
  actor      String
  // "entity.created"|"entity.deactivated"|"entity.reviewed"
  // "case.created"|"case.published"|"evidence.added"
  // "dispute.filed"|"match.queried"|"ingest.completed"
  action     String
  // "CanonicalEntity"|"CaseRecord"|"ArchivedEvidence"|"IntelIngestionBatch"
  targetType String?
  targetId   String?
  detail     Json?
  createdAt  DateTime @default(now())

  @@index([actor, createdAt])
  @@index([action, createdAt])
  @@map("intel_audit_log")
}

// ─────────────────────────────────────────────────────────────────────────────
// LAYER 3 — ANALYST ARCHIVE. Zero scoring path at beta.
// Schema present from day one so capture work can start immediately.
// ─────────────────────────────────────────────────────────────────────────────

model ArchivedEvidence {
  id               String             @id @default(cuid())
  originalUrl      String?
  archiveUrl       String?
  archiveTimestamp DateTime?
  platform         ArchivePlatform
  captureType      CaptureType
  evidenceType     EvidenceType
  // @handle or username — stored but never shown to retail
  authorHandle     String?
  // Analyst note on what this evidence demonstrates
  description      String?
  // SHA-256 of captured file content for integrity
  sha256Hash       String?
  entityId         String?
  entity           CanonicalEntity?   @relation(fields: [entityId], references: [id])
  caseId           String?
  case             CaseRecord?        @relation(fields: [caseId], references: [id])
  // displaySafety NEVER auto-set to RETAIL_SAFE — evidence is analyst-only
  displaySafety    IntelDisplaySafety @default(INTERNAL_ONLY)
  reviewedBy       String?
  reviewedAt       DateTime?
  // Admin handle who seeded this row
  addedBy          String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([caseId])
  @@index([entityId])
  @@map("intel_archived_evidence")
}

// ── LAUNDRY TRAIL MODULE ──

enum LaundryRisk {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum RecoveryDifficulty {
  LOW
  PARTIAL
  SEVERE
}

enum SignalFamily {
  FRAG
  BRIDGE
  MIXER
  PRIV
  DEG
  CASH
}

enum SignalSeverity {
  WEAK
  MODERATE
  STRONG
}

model LaundryTrail {
  id                 String             @id @default(cuid())
  kolHandle          String?
  walletAddress      String
  chain              String
  trailType          String
  laundryRisk        LaundryRisk
  recoveryDifficulty RecoveryDifficulty
  trailBreakHop      Int?
  fundsUnresolved    Float?
  narrativeText      String?
  narrativeTextFr    String?
  evidenceNote       String             @default("Pattern detected via on-chain analysis. INTERLIGENS does not assert intent.")
  evidenceNoteFr     String?            @default("Schéma détecté via une analyse on-chain. INTERLIGENS ne se prononce pas sur l'intention.")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  signals            LaundrySignal[]
  kolProfile         KolProfile?        @relation(fields: [kolHandle], references: [handle])
}

model LaundrySignal {
  id        String         @id @default(cuid())
  trailId   String
  family    SignalFamily
  confirmed Boolean
  severity  SignalSeverity
  detail    String
  rawData   Json?
  trail     LaundryTrail   @relation(fields: [trailId], references: [id], onDelete: Cascade)
}

model KolAlias {
  id        String     @id @default(cuid())
  kolHandle String
  alias     String
  type      String     @default("secondary")
  createdAt DateTime   @default(now())
  kol       KolProfile @relation(fields: [kolHandle], references: [handle], onDelete: Cascade)

  @@unique([kolHandle, alias])
  @@index([alias])
}

model KolTokenLink {
  id                  String     @id @default(cuid())
  kolHandle           String
  contractAddress     String
  chain               String
  tokenSymbol         String?
  role                String     @default("promoter")
  note                String?
  caseId              String?
  documentationStatus String     @default("partial")
  attributionNote     String?
  createdAt           DateTime   @default(now())
  kol                 KolProfile @relation(fields: [kolHandle], references: [handle], onDelete: Cascade)

  @@unique([kolHandle, contractAddress, chain])
  @@index([kolHandle])
}

model EvidenceSnapshot {
  id           String    @id @default(cuid())
  relationType String
  relationKey  String
  snapshotType String
  imageUrl     String?
  title        String
  caption      String
  sourceLabel  String?
  sourceUrl    String?
  observedAt   DateTime?
  displayOrder Int       @default(0)
  isPublic     Boolean   @default(false)
  reviewStatus String    @default("pending")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([relationType, relationKey])
  @@index([isPublic, reviewStatus])
}

model TransparencySubmission {
  id               String               @id @default(cuid())
  submittedHandle  String?
  projectName      String?
  platform         String?              @default("X")
  submitterContact String?
  notes            String?
  status           String               @default("submitted")
  reviewStatus     String               @default("pending")
  publicVisibility String               @default("internal_only")
  reviewedBy       String?
  reviewedAt       DateTime?
  decisionNote     String?
  publicNote       String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  wallets          TransparencyWallet[]

  @@index([status])
  @@index([publicVisibility])
}

model TransparencyWallet {
  id             String                 @id @default(cuid())
  submissionId   String
  chain          String
  address        String
  label          String?
  ownershipClaim String                 @default("self_submitted")
  note           String?
  kolHandle      String?
  isPublic       Boolean                @default(false)
  createdAt      DateTime               @default(now())
  submission     TransparencySubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([chain, address])
}

// ─── ASK INTERLIGENS — AUDIT TRAIL ─────────────────────────────────────────

model AskLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Session / scan context
  sessionId String? // IP hash or investigator session — nullable at beta
  scanId    String? // address being scanned
  locale    String  @default("en")
  source    String  @default("web") // "web" | "mobile"

  // Question / answer
  userQuestion    String
  assistantAnswer String

  // Classification
  answerType     String @default("constrained_generation") // deterministic | constrained_generation | refusal
  mode           String @default("deterministic") // deterministic | exploratory
  confidenceTier String @default("medium") // high | medium | low

  // Sources
  sourcesUsed Json @default("[]") // array of { type, key, present }
  sourceCount Int  @default(0)

  // Performance / debug
  modelName String?
  latencyMs Int?
  metadata  Json?

  @@index([createdAt])
  @@index([scanId])
  @@index([sessionId])
  @@index([answerType])
  @@map("ask_logs")
}

// =========================================================================
// Retail Vision — additive models (feat/retail-vision)
// See MIGRATION_RETAILVISION.md for raw SQL and decisions.
// =========================================================================

model WalletFundingEdge {
  id               String   @id @default(cuid())
  chain            String
  fromWalletId     String?
  toWalletId       String
  fromAddress      String
  toAddress        String
  source           String
  observedAt       DateTime
  confidence       Int      @default(60)
  projectTokenMint String?
  isProjectLinked  Boolean  @default(false)
  raw              Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fromWallet        KolWallet?            @relation("FundingEdgeFrom", fields: [fromWalletId], references: [id], onDelete: SetNull)
  toWallet          KolWallet             @relation("FundingEdgeTo", fields: [toWalletId], references: [id], onDelete: Cascade)
  tokenInvolvements KolTokenInvolvement[]

  @@index([toWalletId, observedAt])
  @@index([chain, toAddress])
  @@index([projectTokenMint, chain])
}

model KolPromotionMention {
  id             String   @id @default(cuid())
  kolHandle      String
  walletId       String?
  chain          String
  tokenMint      String
  tokenSymbol    String?
  sourcePlatform String
  sourcePostId   String
  sourceUrl      String?
  postedAt       DateTime
  contentSnippet String?
  watcherRunId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  kol    KolProfile @relation(fields: [kolHandle], references: [handle], onDelete: Cascade)
  wallet KolWallet? @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@unique([sourcePlatform, sourcePostId])
  @@index([kolHandle, postedAt])
  @@index([chain, tokenMint, postedAt])
}

model TokenLaunchMetric {
  id                 String    @id @default(cuid())
  chain              String
  tokenMint          String
  launchAt           DateTime?
  totalSupply        Decimal?  @db.Decimal(38, 0)
  top3Pct            Decimal?  @db.Decimal(7, 4)
  top10Pct           Decimal?  @db.Decimal(7, 4)
  holderCount        Int?
  concentrationScore Int?
  source             String
  computedAt         DateTime  @default(now())
  raw                Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tokenInvolvements KolTokenInvolvement[]

  @@unique([chain, tokenMint])
  @@index([chain, concentrationScore])
}

model KolTokenInvolvement {
  id                    String    @id @default(cuid())
  kolHandle             String
  walletId              String?
  chain                 String
  tokenMint             String
  firstPromotionAt      DateTime?
  firstBuyAt            DateTime?
  firstSellAt           DateTime?
  avgDumpDelayMinutes   Int?
  soldPct               Decimal?  @db.Decimal(7, 4)
  proceedsUsd           Decimal?  @db.Decimal(20, 2)
  retailLossEstimateUsd Decimal?  @db.Decimal(20, 2)
  isPromoted            Boolean   @default(false)
  isFundedByProject     Boolean   @default(false)
  isFrontRun            Boolean   @default(false)
  projectFundingEdgeId  String?
  launchMetricId        String?
  lastComputedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  kol                KolProfile         @relation(fields: [kolHandle], references: [handle], onDelete: Cascade)
  wallet             KolWallet?         @relation(fields: [walletId], references: [id], onDelete: SetNull)
  projectFundingEdge WalletFundingEdge? @relation(fields: [projectFundingEdgeId], references: [id], onDelete: SetNull)
  launchMetric       TokenLaunchMetric? @relation(fields: [launchMetricId], references: [id], onDelete: SetNull)

  @@unique([kolHandle, chain, tokenMint])
  @@index([chain, tokenMint])
  @@index([kolHandle, lastComputedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVESTIGATORS VAULT — Case Workspace (client-side encrypted)
// Naming: Vault* prefix to avoid collisions with existing CaseFile /
// InvestigatorAuditLog models. Auth pivots on InvestigatorAccess (existing).
// All content fields are opaque ciphertext produced client-side.
// ─────────────────────────────────────────────────────────────────────────────

enum VaultVisibility {
  PRIVATE
  SEMI_PUBLIC
  PUBLIC
}

enum VaultCaseStatus {
  PRIVATE
  SHARED_INTERNAL
  SUBMITTED
  ARCHIVED
}

enum VaultEntityType {
  WALLET
  TX_HASH
  HANDLE
  URL
  DOMAIN
  ALIAS
  EMAIL
  IP
  CONTRACT
  OTHER
}

enum VaultParseStatus {
  PENDING
  PARSED
  PARTIAL
  MANUAL_REQUIRED
  FAILED
}

model VaultInvite {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  email     String
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model VaultProfile {
  id                   String             @id @default(cuid())
  investigatorAccessId String             @unique
  access               InvestigatorAccess @relation(fields: [investigatorAccessId], references: [id])
  handle               String             @unique
  displayName          String?
  bio                  String?
  avatarUrl            String?
  languages            String[]
  specialties          String[]
  coverageZones        String[]
  websiteUrl           String?
  twitterHandle        String?
  telegramHandle       String?
  contactEmail         String?
  visibility           VaultVisibility    @default(PRIVATE)
  isFeatured           Boolean            @default(false)
  isVerified           Boolean            @default(false)
  badges               String[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  nda       VaultNdaAcceptance?
  workspace VaultWorkspace?
  audits    VaultAuditLog[]
}

model VaultNdaAcceptance {
  id                   String             @id @default(cuid())
  investigatorAccessId String             @unique
  access               InvestigatorAccess @relation(fields: [investigatorAccessId], references: [id])
  profileId            String?            @unique
  profile              VaultProfile?      @relation(fields: [profileId], references: [id])
  ndaVersion           String
  ndaDocHash           String // SHA-256 hex digest
  signerName           String
  signedAt             DateTime           @default(now())
  ipAddress            String?
}

model VaultWorkspace {
  id            String       @id @default(cuid())
  profileId     String       @unique
  profile       VaultProfile @relation(fields: [profileId], references: [id])
  kdfSalt       String // hex 32 chars = 16 bytes
  kdfAlgo       String       @default("PBKDF2-SHA256")
  kdfIterations Int          @default(310000)
  encMode       String       @default("CLIENT_SIDE_AES256GCM")
  assistantTokensUsed  Int   @default(0)
  assistantTokensLimit Int   @default(100000)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  cases         VaultCase[]
  audits        VaultAuditLog[]
  networkGraphs VaultNetworkGraph[]
}

model VaultCase {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   VaultWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  titleEnc    String
  titleIv     String
  tagsEnc     String
  tagsIv      String
  status      VaultCaseStatus @default(PRIVATE)
  caseTemplate String?        @default("blank")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  archivedAt  DateTime?

  entities          VaultCaseEntity[]
  files             VaultCaseFile[]
  notes             VaultCaseNote[]
  timeline          VaultCaseTimeline[]
  hypotheses        VaultHypothesis[]
  timelineEvents    VaultTimelineEvent[]
  publishCandidates VaultPublishCandidate[]
  evidenceSnapshots VaultEvidenceSnapshot[]
  exports           CaseExport[]

  @@index([workspaceId])
  @@index([status])
}

enum CaseExportFormat {
  CSV_FULL
  JSON_STRUCTURED
  STIX_LIKE_JSON
  POLICE_ANNEX_PDF
  THREAT_INTEL_CSV
}

model CaseExport {
  id                   String           @id @default(cuid())
  caseId               String
  case                 VaultCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  workspaceId          String
  investigatorAccessId String
  exportFormat         CaseExportFormat
  exportedBy           String
  includedCounts       Json             @default("{}")
  publishabilityFilter String[]         @default([])
  contentHashSha256    String
  iocCount             Int              @default(0)
  snapshotCount        Int              @default(0)
  privateExcluded      Int              @default(0)
  createdAt            DateTime         @default(now())

  @@index([caseId])
  @@index([workspaceId])
  @@index([investigatorAccessId])
}

enum VaultHypothesisStatus {
  OPEN
  CONFIRMED
  REFUTED
  NEEDS_VERIFICATION
}

model VaultHypothesis {
  id                  String                @id @default(cuid())
  caseId              String
  case                VaultCase             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title               String
  status              VaultHypothesisStatus @default(OPEN)
  confidence          Int                   @default(50)
  supportingEntityIds String[]
  notes               String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([caseId])
}

model VaultTimelineEvent {
  id          String    @id @default(cuid())
  caseId      String
  case        VaultCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  eventDate   DateTime
  entityIds   String[]
  eventType   String    @default("MANUAL")
  createdAt   DateTime  @default(now())

  @@index([caseId])
  @@index([eventDate])
}

model VaultPublishCandidate {
  id          String    @id @default(cuid())
  caseId      String
  case        VaultCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  entityIds   String[]
  summary     String
  status      String    @default("PENDING")
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewNote  String?

  @@index([caseId])
  @@index([status])
}

model VaultFeedback {
  id          String   @id @default(cuid())
  workspaceId String
  caseId      String?
  handle      String
  message     String
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}

model VaultCaseShare {
  id                 String   @id @default(cuid())
  caseId             String
  token              String   @unique
  expiresAt          DateTime
  workspaceId        String
  entitySnapshot     Json
  titleSnapshot      String
  hypothesisSnapshot Json?
  createdAt          DateTime @default(now())

  @@index([token])
  @@index([caseId])
}

model VaultCaseEntity {
  id               String          @id @default(cuid())
  caseId           String
  case             VaultCase       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type             VaultEntityType
  value            String
  label            String?
  confidence       Float?
  extractionMethod String?
  sourceFileId     String?
  tigerScore       Int?
  tigerVerdict     String?
  enrichedAt       DateTime?
  createdAt        DateTime        @default(now())

  @@unique([caseId, type, value])
  @@index([caseId])
  @@index([type, value])
}

model VaultCaseFile {
  id            String           @id @default(cuid())
  caseId        String
  case          VaultCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  filenameEnc   String
  filenameIv    String
  mimeType      String
  sizeBytes     Int
  uploadedAt    DateTime         @default(now())
  r2Key         String           @unique // INTERNAL ONLY — never in API responses
  r2Bucket      String           @default("interligens-vaults")
  parseStatus   VaultParseStatus @default(PENDING)
  parsedAt      DateTime?
  entitiesFound Int              @default(0)
  parseMode     String?
  parseError    String?

  @@index([caseId])
}

model VaultCaseNote {
  id         String    @id @default(cuid())
  caseId     String
  case       VaultCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  contentEnc String // opaque ciphertext — server never decrypts
  contentIv  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([caseId])
}

model VaultCaseTimeline {
  id        String    @id @default(cuid())
  caseId    String
  case      VaultCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  eventType String
  payload   Json?
  actor     String
  createdAt DateTime  @default(now())

  @@index([caseId])
}

model VaultAuditLog {
  id                   String              @id @default(cuid())
  investigatorAccessId String?
  access               InvestigatorAccess? @relation(fields: [investigatorAccessId], references: [id])
  profileId            String?
  profile              VaultProfile?       @relation(fields: [profileId], references: [id])
  workspaceId          String?
  workspace            VaultWorkspace?     @relation(fields: [workspaceId], references: [id])
  caseId               String?
  action               String
  actor                String
  ipAddress            String?
  userAgent            String?
  metadata             Json?
  createdAt            DateTime            @default(now())

  @@index([investigatorAccessId])
  @@index([profileId])
  @@index([workspaceId])
  @@index([caseId])
  @@index([action])
}

// ── Vault Evidence Snapshots ─────────────────────────────────────────────────

enum VaultEvidenceSourceType {
  WEBSITE
  X_POST
  TELEGRAM
  DISCORD
  GITHUB
  MEDIUM
  WHITEPAPER
  EXPLORER
  ARKHAM
  METASLEUTH
  DUNE
  CHAINABUSE
  GOPLUS
  SCAMSNIFFER
  OTHER
}

enum VaultEvidencePublishability {
  PRIVATE
  SHAREABLE
  PUBLISHABLE
  REDACTED
}

model VaultEvidenceSnapshot {
  id                   String                      @id @default(cuid())
  caseId               String
  case                 VaultCase                   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  workspaceId          String
  investigatorAccessId String
  url                  String?
  title                String
  sourceType           VaultEvidenceSourceType     @default(OTHER)
  note                 String?
  tags                 String[]
  relatedEntityId      String?
  publishability       VaultEvidencePublishability @default(PRIVATE)
  contentHashSha256    String
  capturedAt           DateTime
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([caseId])
  @@index([workspaceId])
  @@index([publishability])
}

// ── User watch list (post-scan continuous tracking) ──────────────────────────
// Users who scan an address and want to be notified of score/tier/status
// changes can opt in via POST /api/watch. The daily cron re-scans active rows
// and emits WatchAlert records when a material change is detected.
//
// NOTE: `ownerAccessId` stores the InvestigatorAccess.id (not an email) — the
// beta auth system is code-based and has no email field on session.

model WatchedAddress {
  id                 String   @id @default(cuid())
  address            String
  chain              String   // "solana" | "ethereum" | "base" | "arbitrum"
  label              String?
  ownerAccessId      String
  lastScore          Int?
  lastTier           String?
  lastGovernedStatus String?
  lastScannedAt      DateTime?
  alertOnChange      Boolean  @default(true)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  alerts WatchAlert[]

  @@unique([address, chain, ownerAccessId])
  @@index([ownerAccessId])
  @@index([active, lastScannedAt])
}

model WatchAlert {
  id               String         @id @default(cuid())
  watchedAddressId String
  watchedAddress   WatchedAddress @relation(fields: [watchedAddressId], references: [id], onDelete: Cascade)
  previousScore    Int?
  newScore         Int
  previousTier     String?
  newTier          String
  changeType       String         // "tier_change" | "score_change" | "governed_status_change"
  changeDetail     String?
  notifiedAt       DateTime?
  emailSent        Boolean        @default(false)
  createdAt        DateTime       @default(now())

  @@index([watchedAddressId])
}

