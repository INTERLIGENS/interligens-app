generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}







model SourceRegistry {
  id                 String   @id @default(cuid())
  handle             String?  @unique
  sourceName         String
  name               String   @unique
  sourceType         String   @default("other")
  url                String?
  homepageUrl        String?
  description        String?
  defaultChain       String?
  defaultLabelType   String?
  defaultLabel       String?
  defaultVisibility  String   @default("internal_only")
  license            String?
  tosRisk            String   @default("low")
  trusted            Boolean  @default(false)
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  batches            IngestionBatch[]
  templates          SourceTemplate[]
  intakeRecords      IntakeRecord[]
}

model IngestionBatch {
  id            String          @id @default(cuid())
  sourceId      String?
  source        SourceRegistry? @relation(fields: [sourceId], references: [id])
  status        String     @default("pending")
  inputType     String
  inputPayload  String
  totalRows     Int             @default(0)
  matchedAddrs  Int             @default(0)
  dedupedRows   Int             @default(0)
  warnings             String?
  approvedBy           String?
  approvedAt           DateTime?
  processingStartedAt  DateTime?
  processingEndedAt    DateTime?
  processedRows        Int       @default(0)
  errorMessage         String?
  rolledBackAt         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  rawDocuments   RawDocument[]
  labels         AddressLabel[]
  auditLogs      AuditLog[]
  intakeRecords  IntakeRecord[] @relation("IntakePrimary")
  intakeRecords2 IntakeRecord[] @relation("IntakeSecondary")
}

model RawDocument {
  id        String         @id @default(cuid())
  batchId   String
  batch     IngestionBatch @relation(fields: [batchId], references: [id])
  content   String
  mimeType  String         @default("text/plain")
  createdAt DateTime       @default(now())
}

model AddressLabel {
  id          String          @id @default(cuid())
  chain       String
  address     String
  labelType   String
  label       String
  confidence  String          @default("low")
  entityName  String?
  sourceName  String
  sourceUrl   String?
  evidence    String?
  visibility  String          @default("internal_only")
  license     String?
  tosRisk     String          @default("low")
  isActive    Boolean         @default(true)
  firstSeenAt DateTime        @default(now())
  lastSeenAt  DateTime        @default(now())
  batchId     String?
  batch       IngestionBatch? @relation(fields: [batchId], references: [id])

  @@unique([chain, address, labelType, label, sourceUrl], name: "dedup_key")
  @@index([chain, address])
  @@index([batchId])
}

model RiskSummaryCache {
  id        String   @id @default(cuid())
  chain     String
  address   String
  summary   String
  updatedAt DateTime @updatedAt

  @@unique([chain, address], name: "chain_address")
}

model AuditLog {
  id        String          @id @default(cuid())
  action    String
  actorId   String
  batchId   String?
  batch     IngestionBatch? @relation(fields: [batchId], references: [id])
  meta      String?
  createdAt DateTime        @default(now())
}

model SourceTemplate {
  id            String         @id @default(cuid())
  sourceId      String
  source        SourceRegistry @relation(fields: [sourceId], references: [id])
  inputType     String
  columnMapping String
  rules         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model CommunitySubmission {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  status           String   @default("pending")
  chain            String
  address          String
  labelType        String
  label            String?
  message          String?
  evidenceUrl      String?
  txHash           String?
  reporterContact  String?
  ipHash           String
  userAgentHash    String?
  source           String   @default("community")
  severityDerived  String   @default("info")
  adminNotes       String?
  linkedBatchId    String?
}

model GraphCase {
  id           String      @id @default(cuid())
  title        String
  pivotAddress String
  chain        String
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  nodes        GraphNode[]
  edges        GraphEdge[]
}

model GraphNode {
  id       String      @id @default(cuid())
  caseId   String
  type     String
  label    String
  metadata String      @default("{}")
  posX     Float       @default(0)
  posY     Float       @default(0)
  flagged  Boolean     @default(false)
  case     GraphCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  edgesOut GraphEdge[] @relation("EdgeSource")
  edgesIn  GraphEdge[] @relation("EdgeTarget")
}

model GraphEdge {
  id         String    @id @default(cuid())
  caseId     String
  sourceId   String
  targetId   String
  relation   String
  evidence   String?
  confidence String    @default("MEDIUM")
  case       GraphCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  source     GraphNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target     GraphNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model WalletLabel {
  id          String   @id @default(cuid())
  address     String
  chain       String
  label       String
  category    String
  confidence  String   @default("MEDIUM")
  source      String
  sourceUrl   String?
  verified    Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([address])
  @@index([chain])
  @@index([category])
  @@index([verified])
}

model IntakeRecord {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  status           String          @default("pending")
  inputType        String
  sourceRef        String?
  sourceId         String?
  source           SourceRegistry? @relation(fields: [sourceId], references: [id])
  submittedBy      String?
  provenance       String          @default("{}")
  parserUsed       String          @default("unknown")
  extractVersion   String          @default("v1")
  rawText          String?
  rawTextTruncated Boolean         @default(false)
  extracted        String          @default("{}")
  classification   String          @default("rawdoc")
  routerConfidence Float           @default(0)
  extractWarnings  String          @default("[]")
  pendingBatch     Boolean         @default(false)
  linkedBatchId    String?
  linkedBatch      IngestionBatch? @relation("IntakePrimary", fields: [linkedBatchId], references: [id])
  linkedBatchId2   String?
  linkedBatch2     IngestionBatch? @relation("IntakeSecondary", fields: [linkedBatchId2], references: [id])
  ipHash           String?
  userAgentHash    String?
  adminNotes       String?
}

model KolProfile {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  handle          String   @unique
  platform        String   @default("x")
  label           String   @default("unknown")
  riskFlag        String   @default("unverified")
  wallets         String   @default("[]")
  sourceIntakeIds String   @default("[]")
  confidence      String   @default("low")
  status          String   @default("active")
  tier            String?
  pricePerPost    Float?
  followerCount   Int?
  bio             String?
  tags            String   @default("[]")
  notes           String?
}

model DomainIoc {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  domain        String   @unique
  labelType     String   @default("phishing")
  confidence    String   @default("low")
  status        String   @default("active")
  sourceIntakeId String?
  notes         String?
}

model WatchSource {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  name         String
  url          String    @unique
  investigator String    @default("@david")
  tags         String    @default("[]")
  active       Boolean   @default(true)
  lastChecked  DateTime?
  lastHash     String?
  lastIntakeId String?
  errorCount   Int       @default(0)
}
model Influencer {
  id        String   @id @default(cuid())
  handle    String   @unique
  platform  String   @default("x")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallets     Wallet[]
  socialPosts SocialPost[]
  signals     Signal[]
  watchlist   SocialWatchlist?
  candidates  SocialPostCandidate[]
  score       InfluencerScore?

  @@map("influencers")
}

model Wallet {
  id             String   @id @default(cuid())
  address        String
  chain          String   @default("ethereum")
  influencerId   String
  verifiedMethod String   // "ENS_ONCHAIN" | "POST_X" | "ARKHAM" | "MANUAL"
  verifiedAt     DateTime
  confidence     Float    @default(1.0)
  ensName        String?
  createdAt      DateTime @default(now())

  influencer    Influencer     @relation(fields: [influencerId], references: [id])
  onchainEvents OnchainEvent[]

  @@unique([address, chain])
  @@map("wallets")
}

enum CaptureStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  BLOCKED
}

model SocialPost {
  id               String        @id @default(cuid())
  influencerId     String
  postUrl          String
  postedAtUtc      DateTime?
  capturedAtUtc    DateTime
  textExcerpt      String?       @db.VarChar(500)
  screenshotSha256 String?
  htmlSha256       String?
  manifestSha256   String?
  storageKeys      Json?
  captureStatus    CaptureStatus @default(PENDING)
  errors           String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id])
  signals    Signal[]

  @@map("social_posts")
}

// Phase B placeholder
model OnchainEvent {
  id            String   @id @default(cuid())
  txHash        String   @unique
  walletAddress String
  chain         String   @default("ethereum")
  blockTimeUtc  DateTime
  blockNumber   Int
  tokenAddress  String?
  direction     String?
  amountRaw     String?
  amountUsd     Float?
  counterparty  String?
  rawJson       Json?
  createdAt     DateTime @default(now())

  wallet  Wallet?  @relation(fields: [walletAddress, chain], references: [address, chain])
  signals Signal[]

  @@map("onchain_events")
}

// Phase C placeholder
model Signal {
  id                       String    @id @default(cuid())
  type                     String
  influencerId             String
  walletAddress            String?
  tokenAddress             String?
  t0PostUrl                String?
  t0PostedAtUtc            DateTime?
  t0CapturedAtUtc          DateTime?
  t0CapturedManifestSha256 String?
  t0Post                   DateTime?
  t1TxHash                 String?
  t1BlockNumber            Int?
  t1BlockTimeUtc           DateTime?
  t1Event                  DateTime?
  direction                String?
  amountRaw                String?
  holdingBeforeRaw         String?
  soldPctOfHolding         Float?
  windowBucket             String?
  windowMinutes            Int?
  severity                 String?
  confidence               Float?
  evidenceManifestSha256   String?
  evidenceRefs             Json?
  socialPostId             String?
  onchainEventId           String?
  notes                    String?
  createdAt                DateTime  @default(now())

  influencer   Influencer    @relation(fields: [influencerId], references: [id])
  socialPost   SocialPost?   @relation(fields: [socialPostId], references: [id])
  onchainEvent OnchainEvent? @relation(fields: [onchainEventId], references: [id])

  @@map("signals")
}

model InfluencerScore {
  id            String   @id @default(cuid())
  influencerId  String   @unique
  periodDays    Int      @default(30)
  score         Int      @default(0)
  blatantCount  Int      @default(0)
  probableCount Int      @default(0)
  possibleCount Int      @default(0)
  updatedAt     DateTime @default(now())

  influencer Influencer @relation(fields: [influencerId], references: [id])

  @@map("influencer_scores")
}



model SocialWatchlist {
  id             String    @id @default(cuid())
  influencerId   String    @unique
  handle         String
  provider       String    @default("nitter_rss")
  status         String    @default("active")
  lastCheckedAt  DateTime?
  lastSeenPostId String?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id])

  @@map("social_watchlist")
}

model SocialPostCandidate {
  id                 String    @id @default(cuid())
  influencerId       String
  watchlistId        String?
  postUrl            String
  postId             String
  discoveredAtUtc    DateTime  @default(now())
  postedAtUtc        DateTime?
  sourceProvider     String
  status             String    @default("new")
  attempts           Int       @default(0)
  lastAttemptAtUtc   DateTime?
  errorMessage       String?
  linkedSocialPostId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  influencer Influencer @relation(fields: [influencerId], references: [id])

  @@unique([postId, influencerId])
  @@map("social_post_candidates")
}

model AlertSubscription {
  id                String   @id @default(cuid())
  email             String?
  webhookUrl        String?
  handles           String   @default("[]")
  severityThreshold String   @default("PROBABLE")
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deliveries AlertDelivery[]

  @@map("alert_subscriptions")
}

model AlertDelivery {
  id             String    @id @default(cuid())
  subscriptionId String
  signalId       String
  status         String    @default("pending")
  channel        String
  deliveredAt    DateTime?
  error          String?
  createdAt      DateTime  @default(now())

  subscription AlertSubscription @relation(fields: [subscriptionId], references: [id])

  @@map("alert_deliveries")
}

model CaseFile {
  id          String    @id @default(cuid())
  signalId    String    @unique
  storageKey  String?
  pdfSha256   String?
  status      String    @default("pending")
  generatedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@map("casefiles")
}

model KOLProfile {
  id            String   @id @default(cuid())
  handle        String   @unique
  platform      String
  displayName   String?
  followers     Int?
  avatarUrl     String?
  status        String   @default("active")
  totalScammed  Float?
  rugCount      Int      @default(0)
  firstSeenAt   DateTime?
  lastSeenAt    DateTime?
  notes         String?
  verified      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  wallets       KOLWallet[]
  caseLinks     KOLCaseLink[]
  @@index([handle])
  @@index([platform])
}

model KOLWallet {
  id         String   @id @default(cuid())
  kolId      String
  address    String
  chain      String
  label      String?
  status     String   @default("active")
  totalIn    Float?
  totalOut   Float?
  createdAt  DateTime @default(now())
  kol        KOLProfile @relation(fields: [kolId], references: [id], onDelete: Cascade)
  @@index([kolId])
  @@index([address])
}

model KOLCaseLink {
  id        String   @id @default(cuid())
  kolId     String
  caseId    String
  role      String
  paidUsd   Float?
  evidence  String?
  createdAt DateTime @default(now())
  kol       KOLProfile @relation(fields: [kolId], references: [id], onDelete: Cascade)
  @@index([kolId])
  @@index([caseId])
}
