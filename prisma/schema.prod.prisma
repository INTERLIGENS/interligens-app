  scanRunId    String?
  mmEntityId   String?

  mmEntity MmEntity? @relation(fields: [mmEntityId], references: [id])

  @@index([subjectId, chain])
  @@index([detectorType])
  @@index([detectedAt])
}

model MmScore {
  id                  String        @id @default(cuid())
  subjectType         MmSubjectType
  subjectId           String
  chain               MmChain
  registryDrivenScore Int
  behaviorDrivenScore Int
  displayScore        Int
  band                MmRiskBand
  confidence          String
  coverage            String
  dominantDriver      String
  displayReason       String
  breakdown           Json
  signalsCount        Int
  scanRunId           String
  computedAt          DateTime      @default(now())
  expiresAt           DateTime
  schemaVersion       Int           @default(1)

  @@unique([subjectType, subjectId, chain])
  @@index([computedAt])
