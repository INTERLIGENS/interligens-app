generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}







model SourceRegistry {
  id                 String   @id @default(cuid())
  handle             String?  @unique
  sourceName         String
  name               String   @unique
  sourceType         String   @default("other")
  url                String?
  homepageUrl        String?
  description        String?
  defaultChain       String?
  defaultLabelType   String?
  defaultLabel       String?
  defaultVisibility  String   @default("internal_only")
  license            String?
  tosRisk            String   @default("low")
  trusted            Boolean  @default(false)
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  batches            IngestionBatch[]
  templates          SourceTemplate[]
  intakeRecords      IntakeRecord[]
}

model IngestionBatch {
  id            String          @id @default(cuid())
  sourceId      String?
  source        SourceRegistry? @relation(fields: [sourceId], references: [id])
  status        String     @default("pending")
  inputType     String
  inputPayload  String
  totalRows     Int             @default(0)
  matchedAddrs  Int             @default(0)
  dedupedRows   Int             @default(0)
  warnings             String?
  approvedBy           String?
  approvedAt           DateTime?
  processingStartedAt  DateTime?
  processingEndedAt    DateTime?
  processedRows        Int       @default(0)
  errorMessage         String?
  rolledBackAt         DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  rawDocuments   RawDocument[]
  labels         AddressLabel[]
  auditLogs      AuditLog[]
  intakeRecords  IntakeRecord[] @relation("IntakePrimary")
  intakeRecords2 IntakeRecord[] @relation("IntakeSecondary")
}

model RawDocument {
  id        String         @id @default(cuid())
  batchId   String
  batch     IngestionBatch @relation(fields: [batchId], references: [id])
  content   String
  mimeType  String         @default("text/plain")
  createdAt DateTime       @default(now())
}

model AddressLabel {
  id          String          @id @default(cuid())
  chain       String
  address     String
  labelType   String
  label       String
  confidence  String          @default("low")
  entityName  String?
  sourceName  String
  sourceUrl   String?
  evidence    String?
  visibility  String          @default("internal_only")
  license     String?
  tosRisk     String          @default("low")
  isActive    Boolean         @default(true)
  firstSeenAt DateTime        @default(now())
  lastSeenAt  DateTime        @default(now())
  batchId     String?
  batch       IngestionBatch? @relation(fields: [batchId], references: [id])

  @@unique([chain, address, labelType, label, sourceUrl], name: "dedup_key")
  @@index([chain, address])
  @@index([batchId])
}

model RiskSummaryCache {
  id        String   @id @default(cuid())
  chain     String
  address   String
  summary   String
  updatedAt DateTime @updatedAt

  @@unique([chain, address], name: "chain_address")
}

model AuditLog {
  id        String          @id @default(cuid())
  action    String
  actorId   String
  batchId   String?
  batch     IngestionBatch? @relation(fields: [batchId], references: [id])
  meta      String?
  createdAt DateTime        @default(now())
}

model SourceTemplate {
  id            String         @id @default(cuid())
  sourceId      String
  source        SourceRegistry @relation(fields: [sourceId], references: [id])
  inputType     String
  columnMapping String
  rules         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model CommunitySubmission {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  status           String   @default("pending")
  chain            String
  address          String
  labelType        String
  label            String?
  message          String?
  evidenceUrl      String?
  txHash           String?
  reporterContact  String?
  ipHash           String
  userAgentHash    String?
  source           String   @default("community")
  severityDerived  String   @default("info")
  adminNotes       String?
  linkedBatchId    String?
}

model GraphCase {
  id           String      @id @default(cuid())
  title        String
  pivotAddress String
  chain        String
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  nodes        GraphNode[]
  edges        GraphEdge[]
}

model GraphNode {
  id       String      @id @default(cuid())
  caseId   String
  type     String
  label    String
  metadata String      @default("{}")
  posX     Float       @default(0)
  posY     Float       @default(0)
  flagged  Boolean     @default(false)
  case     GraphCase   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  edgesOut GraphEdge[] @relation("EdgeSource")
  edgesIn  GraphEdge[] @relation("EdgeTarget")
}

model GraphEdge {
  id         String    @id @default(cuid())
  caseId     String
  sourceId   String
  targetId   String
  relation   String
  evidence   String?
  confidence String    @default("MEDIUM")
  case       GraphCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  source     GraphNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target     GraphNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model WalletLabel {
  id          String   @id @default(cuid())
  address     String
  chain       String
  label       String
  category    String
  confidence  String   @default("MEDIUM")
  source      String
  sourceUrl   String?
  verified    Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([address])
  @@index([chain])
  @@index([category])
  @@index([verified])
}

model IntakeRecord {
  id               String          @id @default(cuid())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  status           String          @default("pending")
  inputType        String
  sourceRef        String?
  sourceId         String?
  source           SourceRegistry? @relation(fields: [sourceId], references: [id])
  submittedBy      String?
  provenance       String          @default("{}")
  parserUsed       String          @default("unknown")
  extractVersion   String          @default("v1")
  rawText          String?
  rawTextTruncated Boolean         @default(false)
  extracted        String          @default("{}")
  classification   String          @default("rawdoc")
  routerConfidence Float           @default(0)
  extractWarnings  String          @default("[]")
  pendingBatch     Boolean         @default(false)
  linkedBatchId    String?
  linkedBatch      IngestionBatch? @relation("IntakePrimary", fields: [linkedBatchId], references: [id])
  linkedBatchId2   String?
  linkedBatch2     IngestionBatch? @relation("IntakeSecondary", fields: [linkedBatchId2], references: [id])
  ipHash           String?
  userAgentHash    String?
  adminNotes       String?
}

model KolProfile {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  handle          String   @unique
  platform        String   @default("x")
  label           String   @default("unknown")
  riskFlag        String   @default("unverified")
  wallets         String   @default("[]")
  sourceIntakeIds String   @default("[]")
  confidence      String   @default("low")
  status          String   @default("active")
  tier            String?
  pricePerPost    Float?
  followerCount   Int?
  bio             String?
  tags            String   @default("[]")
  notes           String?
}

model DomainIoc {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  domain        String   @unique
  labelType     String   @default("phishing")
  confidence    String   @default("low")
  status        String   @default("active")
  sourceIntakeId String?
  notes         String?
}

model WatchSource {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  name         String
  url          String    @unique
  investigator String    @default("@david")
  tags         String    @default("[]")
  active       Boolean   @default(true)
  lastChecked  DateTime?
  lastHash     String?
  lastIntakeId String?
  errorCount   Int       @default(0)
}
