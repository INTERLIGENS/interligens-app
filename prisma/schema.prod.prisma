// All models below are additive. The corresponding SQL lives at
// prisma/migrations/manual_security_center/migration.sql and MUST be pasted
// in the Neon SQL Editor (after taking a branch snapshot) before any code
// that queries these tables is activated. Project rule: migrations via Neon
// Console only, no `prisma db push`, no `prisma migrate dev` against prod.

model SecurityVendor {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  category         String // hosting | database | repo | dependency | auth | monitoring | social | storage | infra | ci_cd | package_registry | other
  isActive         Boolean  @default(true)
  websiteUrl       String?
  statusPageUrl    String?
  rssUrl           String?
  atomUrl          String?
  webhookSupported Boolean  @default(false)
  emailSupported   Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sources       SecuritySource[]
  incidents     SecurityIncident[]
  exposureLinks SecurityVendorExposureLink[]

  @@index([category])
  @@index([isActive])
}

model SecuritySource {
  id                  String   @id @default(cuid())
  vendorId            String?
  sourceType          String // statuspage | advisory_db | rss | webhook | manual | internal_audit | vendor_blog | github_advisory
  name                String
  url                 String
  isActive            Boolean  @default(true)
  pollIntervalMinutes Int?
  lastPolledAt        DateTime?
  lastStatus          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  vendor    SecurityVendor?    @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  incidents SecurityIncident[]

  @@index([vendorId])
  @@index([sourceType])
  @@index([isActive])
}

model SecurityIncident {
  id           String    @id @default(cuid())
  vendorId     String?
  sourceId     String?
  externalId   String?
  title        String
  summaryShort String
  summaryLong  String?
  incidentType String // outage | security_incident | breach | unauthorized_access | supply_chain | malware | secret_leak | dependency_cve | phishing | account_takeover | data_exposure | ddos | abuse | intimidation | internal_suspicion | other
  severity     String // info | low | medium | high | critical
  status       String    @default("open") // open | investigating | monitoring | identified | mitigated | resolved | archived
  detectedAt   DateTime
  occurredAt   DateTime?
  resolvedAt   DateTime?
  sourceUrl    String?
  rawPayload   Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  vendor      SecurityVendor?              @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  source      SecuritySource?              @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  assessments SecurityExposureAssessment[]
  actionItems SecurityActionItem[]
  comms       SecurityCommsDraft[]

  @@unique([vendorId, externalId])
  @@index([status])
  @@index([severity])
  @@index([detectedAt(sort: Desc)])
  @@index([vendorId])
}

model SecurityExposureAssessment {
  id                       String   @id @default(cuid())
  incidentId               String
  exposureLevel            String // none | unlikely | possible | probable | confirmed
  affectedSurface          Json
  requiresKeyRotation      Boolean  @default(false)
  requiresAccessReview     Boolean  @default(false)
  requiresInfraLogReview   Boolean  @default(false)
  requiresPublicStatement  Boolean  @default(false)
  actionChecklist          Json
  analystNote              String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  incident SecurityIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([exposureLevel])
}

model SecurityAsset {
