{"mint":"BYZ9CcZGKAXmN2uDsKcQMM9UnZacja4vWcns9Th69xb","chain":"solana","scanned_at":"2026-02-28T09:10:14.470Z","off_chain":{"status":"Referenced","source":"case_db","case_id":"CASE-2024-BOTIFY-001","summary":"BOTIFY token on Solana exhibits multiple high-severity rug-pull indicators: anonymous team, no locked liquidity, coordinated shill campaigns, and abrupt social media abandonment post-launch. Eight independent claims corroborated by screenshot evidence.","claims":[{"id":"C1","title":"Coordinated Shill Campaign","severity":"HIGH","status":"CONFIRMED","description":"Multiple bot accounts posted identical promotional content within minutes of each other, displaying classic coordinated pump behaviour.","evidence_files":["IMG_2239.jpg"],"thread_url":"https://twitter.com/search?q=%24BOTIFY&src=typed_query","category":"social_manipulation"},{"id":"C2","title":"Insider Pre-Launch Pump Signal","severity":"HIGH","status":"CONFIRMED","description":"Telegram group messages show buy signals distributed to insiders 45 minutes before public token listing, enabling front-running.","evidence_files":["IMG_2240.jpg"],"thread_url":"https://t.me/+BOTIFY_insiders","category":"insider_trading"},{"id":"C3","title":"Liquidity Withdrawal < 30 min Post-Peak","severity":"CRITICAL","status":"CONFIRMED","description":"On-chain data confirms the deployer wallet removed 100% of liquidity from the primary Raydium pool within 28 minutes of the price peak, causing a 97% collapse.","evidence_files":["IMG_2241.jpg"],"thread_url":"https://dexscreener.com/solana/BYZ9CcZGKAXmN2uDsKcQMM9UnZacja4vWcns9Th69xb","category":"rug_pull"},{"id":"C4","title":"Pre-funded Wallet Cluster (Sybil)","severity":"HIGH","status":"CONFIRMED","description":"Seven wallets received identical SOL amounts from a single source wallet 2 hours before launch. All seven sold at peak within a 90-second window.","evidence_files":["IMG_2242.jpg"],"thread_url":"https://solscan.io/token/BYZ9CcZGKAXmN2uDsKcQMM9UnZacja4vWcns9Th69xb","category":"sybil_attack"},{"id":"C5","title":"Mint & Freeze Authority Not Revoked","severity":"CRITICAL","status":"CONFIRMED","description":"Rugcheck.xyz confirms mint authority and freeze authority both remain active on the token contract, allowing the deployer to mint unlimited supply or freeze any holder wallet.","evidence_files":["IMG_2243.jpg"],"thread_url":"https://rugcheck.xyz/tokens/BYZ9CcZGKAXmN2uDsKcQMM9UnZacja4vWcns9Th69xb","category":"contract_risk"},{"id":"C6","title":"Anonymous Team / Same-Day Domain","severity":"MEDIUM","status":"CONFIRMED","description":"Project website domain was registered on the same day as token launch. No team identities, CVs, or verifiable social accounts exist. WHOIS data is privacy-protected.","evidence_files":["IMG_2244.jpg"],"thread_url":null,"category":"identity_risk"},{"id":"C7","title":"Whale Concentration — Top 3 Wallets Hold 62%","severity":"HIGH","status":"CONFIRMED","description":"At peak, the top 3 holder wallets controlled 62% of circulating supply, indicating extreme insider accumulation and the ability to crash price at will.","evidence_files":["IMG_2245.jpg"],"thread_url":"https://solscan.io/token/BYZ9CcZGKAXmN2uDsKcQMM9UnZacja4vWcns9Th69xb#holders","category":"tokenomics_risk"},{"id":"C8","title":"Social Media Abandonment Post-Launch","severity":"HIGH","status":"CONFIRMED","description":"All official BOTIFY social channels (Twitter, Telegram, Discord) went completely silent on day 5 after launch. No developer responses to community distress signals.","evidence_files":["IMG_2246.jpg"],"thread_url":null,"category":"project_abandonment"}],"sources":[{"source_id":"SRC-001","filename":"IMG_2239.jpg","caption":"Twitter/X shill campaign — coordinated bot replies boosting $BOTIFY","type":"screenshot"},{"source_id":"SRC-002","filename":"IMG_2240.jpg","caption":"Telegram pump group — pre-launch insider buy signals for BOTIFY","type":"screenshot"},{"source_id":"SRC-003","filename":"IMG_2241.jpg","caption":"DexScreener liquidity chart — LP withdrawn < 30 min after launch peak","type":"screenshot"},{"source_id":"SRC-004","filename":"IMG_2242.jpg","caption":"Solscan wallet cluster — 7 wallets pre-funded from same source 2h before launch","type":"screenshot"},{"source_id":"SRC-005","filename":"IMG_2243.jpg","caption":"Rugcheck.xyz report — Mint Authority NOT revoked, Freeze Authority active","type":"screenshot"},{"source_id":"SRC-006","filename":"IMG_2244.jpg","caption":"Website WHOIS — domain registered same day as token launch, no team doxxing","type":"screenshot"},{"source_id":"SRC-007","filename":"IMG_2245.jpg","caption":"Holder distribution — top 3 wallets hold 62% of supply (insider accumulation)","type":"screenshot"},{"source_id":"SRC-008","filename":"IMG_2246.jpg","caption":"Social media abandonment — all official channels silent after day 5 post-launch","type":"screenshot"}]},"on_chain":{"markets":{"source":null,"primary_pool":null,"dex":null,"url":null,"price":null,"liquidity_usd":null,"volume_24h_usd":null,"fdv_usd":null,"fetched_at":"2026-02-28T09:10:14.469Z","cache_hit":false}},"risk":{"score":100,"tier":"RED","breakdown":{"base_score":0,"claim_penalty":85,"severity_multiplier":1.2},"flags":["confirmed_claims=8","CRITICAL_CLAIM_PRESENT"]}}