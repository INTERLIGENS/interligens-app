{
  "manifest_version": 3,
  "name": "INTERLIGENS Guard",
  "version": "0.1.0",
  "description": "Forensic risk warnings on pump.fun, Jupiter, Raydium, Birdeye & DexScreener.",
  "permissions": [],
  "host_permissions": [
    "https://interligens.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pump.fun/*",
        "https://jup.ag/*",
        "https://raydium.io/*",
        "https://birdeye.so/*",
        "https://dexscreener.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "INTERLIGENS Guard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
